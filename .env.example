DATABASE_URL=              # MySQL/TiDB connection string
RESEND_API_KEY=            # Resend API key for email delivery
STRIPE_SECRET_KEY=         # Stripe secret key for billing
IMPERSONATION_JWT_SECRET=  # Secret used to sign impersonation JWT tokens
JAIME_ENV=staging          # Set to 'staging' or 'production'
PA_ACCESS_KEY=             # Amazon PA API access key
PA_SECRET_KEY=             # Amazon PA API secret key
PA_PARTNER_TAG=            # Amazon Associates partner tag (e.g. mypub-20)
PA_HOST=webservices.amazon.com  # PA API host (us-east-1 default)
YOUTUBE_API_KEY=    # YouTube Data API v3 key — required for YouTube listening feature
